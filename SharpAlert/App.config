<?xml version="1.0" encoding="utf-8"?>
<configuration>
    <configSections>
        <sectionGroup name="userSettings" type="System.Configuration.UserSettingsGroup, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089">
            <section name="SharpAlert.Properties.Settings" type="System.Configuration.ClientSettingsSection, System, Version=4.0.0.0, Culture=neutral, PublicKeyToken=b77a5c561934e089" allowExeDefinition="MachineToLocalUser" requirePermission="false" />
        </sectionGroup>
    </configSections>
    <startup> 
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8" />
    </startup>
    <userSettings>
        <SharpAlert.Properties.Settings>
            <setting name="statusTest" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="statusActual" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="messageTypeAlert" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="messageTypeUpdate" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="messageTypeCancel" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="messageTypeTest" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="severityExtreme" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="severitySevere" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="severityModerate" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="severityMinor" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="severityUnknown" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="urgencyImmediate" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="urgencyExpected" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="urgencyFuture" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="urgencyPast" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="AllowedSAMELocations_Geocodes" serializeAs="Xml">
                <value>
                    <ArrayOfString xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
                </value>
            </setting>
            <setting name="EnforceEventBlacklist" serializeAs="Xml">
                <value>
                    <ArrayOfString xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
                </value>
            </setting>
            <setting name="AlertCheckInterval" serializeAs="String">
                <value>45</value>
            </setting>
            <setting name="AllowedUGCLocations_Geocodes" serializeAs="Xml">
                <value>
                    <ArrayOfString xmlns:xsd="http://www.w3.org/2001/XMLSchema" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" />
                </value>
            </setting>
            <setting name="weaOnly" serializeAs="String">
                <value>True</value>
            </setting>
            <setting name="discardFirstAlerts" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="DiscordWebhook" serializeAs="String">
                <value />
            </setting>
            <setting name="DiscordWebhookAppend" serializeAs="String">
                <value />
            </setting>
            <setting name="alertFullscreen" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="alertFullscreenDisplay" serializeAs="String">
                <value>0</value>
            </setting>
            <setting name="urgencyUnknown" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="alertFullscreenIdle" serializeAs="String">
                <value>False</value>
            </setting>
            <setting name="alertTimeout" serializeAs="String">
                <value>5</value>
            </setting>
            <setting name="alertCompatibilityMode" serializeAs="String">
                <value>False</value>
            </setting>
        </SharpAlert.Properties.Settings>
    </userSettings>
  <runtime>
    <assemblyBinding xmlns="urn:schemas-microsoft-com:asm.v1">
      <dependentAssembly>
        <assemblyIdentity name="System.Runtime.CompilerServices.Unsafe" publicKeyToken="b03f5f7f11d50a3a" culture="neutral" />
